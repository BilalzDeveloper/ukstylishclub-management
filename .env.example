# ─────────────────────────────────────────────────────────────
# Store OS — environment variables (copy to .env and fill in)
# ─────────────────────────────────────────────────────────────

# --- Database ---
DATABASE_URL="postgresql://user:password@localhost:5432/storeos?schema=public"

# --- Shopify Admin API ---
# Custom/private app token from your store's admin (Settings → Apps → Develop apps)
SHOPIFY_STORE_DOMAIN="your-store.myshopify.com"
SHOPIFY_ADMIN_ACCESS_TOKEN="shpat_xxxxxxxxxxxxxxxxxxxxxxxx"
SHOPIFY_API_VERSION="2025-01"
# Secret used to verify incoming Shopify webhooks (orders/create, fulfillment, ...)
SHOPIFY_WEBHOOK_SECRET="xxxxxxxxxxxxxxxxxxxxxxxx"

# --- Telegram (grammY) ---
# Bot used for vendor intake AND customer payment-proof + DM catalog
TELEGRAM_BOT_TOKEN="123456:ABC-DEF..."
# Secret token Telegram echoes back on each webhook call (setWebhook secret_token)
TELEGRAM_WEBHOOK_SECRET="xxxxxxxxxxxxxxxxxxxxxxxx"
# Public channel/group the daily catalog is broadcast to
TELEGRAM_CATALOG_CHANNEL_ID="@your_catalog_channel"

# --- Meta (WhatsApp Cloud API + Instagram Graph API) ---
# App + credentials live in the companion Facebook-Apps repo; values referenced here
META_APP_ID=""
META_APP_SECRET=""
META_WHATSAPP_PHONE_NUMBER_ID=""
META_WHATSAPP_ACCESS_TOKEN=""
META_WEBHOOK_VERIFY_TOKEN=""
META_INSTAGRAM_BUSINESS_ACCOUNT_ID=""

# --- AI (Anthropic / Claude) ---
# Image analysis (product extraction) + payment-proof OCR/matching
ANTHROPIC_API_KEY="sk-ant-xxxxxxxxxxxxxxxxxxxxxxxx"
# Fast/cheap model for routine extraction; larger model only on low confidence
AI_MODEL_FAST="claude-haiku-4-5-20251001"
AI_MODEL_SMART="claude-opus-4-8"

# --- Payment / settlement ---
# Bank/wallet details shown to customers at checkout & in payment instructions
PAYOUT_BANK_DETAILS="Bank: ... | IBAN: ... | Wallet: ..."
# How long an unpaid order waits for proof before auto-cancel + restock (minutes)
ORDER_PAYMENT_EXPIRY_MINUTES="1440"
# Acceptable +/- tolerance when matching a proof amount to the order total
PAYMENT_MATCH_TOLERANCE="0.01"

# --- App ---
APP_BASE_URL="http://localhost:3000"
# Comma-separated emails allowed into the admin dashboard
ADMIN_ALLOWLIST="bilalshami@gmail.com"
